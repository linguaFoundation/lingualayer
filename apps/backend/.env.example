# LinguaLayer API
NODE_ENV=development
PORT=8080
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000

# Stellar / SEP-0010
# A random keypair is generated at startup when this is unset (dev only).
# In production, set this to a stable Stellar secret key (S...).
SERVER_KEYPAIR_SECRET=
STELLAR_NETWORK=testnet
WEB_AUTH_DOMAIN=lingualayer.io

# JWT — must be a long random string in production
JWT_SECRET=replace-with-a-strong-random-secret
