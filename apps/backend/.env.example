# LinguaLayer API
NODE_ENV=development
PORT=8080
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000

# --- DatasetRegistry event indexer ---
# Postgres connection string (required by `npm run indexer:start`).
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/lingualayer
# Soroban RPC endpoint (defaults to testnet).
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Deployed DatasetRegistry contract id (defaults to the testnet address).
DATASET_REGISTRY_CONTRACT_ID=CBET4YWSMIZB3LGLVTDKQJ5HXQAPQGM3NKGXJLJEJQNF7TBDOVMXUOK
# Ledger to start indexing from when no cursor exists yet.
INDEXER_START_LEDGER=1
# Delay between poll cycles (ms).
INDEXER_POLL_INTERVAL_MS=5000
# Max events fetched per poll.
INDEXER_PAGE_SIZE=100
